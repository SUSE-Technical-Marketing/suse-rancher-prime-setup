{
    "name": "@suse-tmm/kubernetes-apps",
    "version": "0.1.0",
    "description": "Pulumi components for Kubernetes app deployments, TLS, and ingress",
    "main": "bin/index.js",
    "types": "bin/index.d.ts",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/SUSE-Technical-Marketing/suse-rancher-prime-setup.git"
    },
    "peerDependencies": {
        "@pulumi/kubernetes": "^4.23.0",
        "@pulumi/pulumi": "^3.171.0"
    },
    "scripts": {
        "generate": "crd2pulumi --nodejsPath generated crd-sources/*.yaml --force && rm -f generated/package.json generated/tsconfig.json generated/README.md && rm -rf generated/scripts",
        "build": "tsc -p .",
        "prepublishOnly": "npm run build"
    },
    "devDependencies": {
        "@types/node": "^22.15.23",
        "typescript": "^5.8.3"
    },
    "dependencies": {
        "@pulumi/command": "^1.1.2",
        "@pulumi/kubernetes": "^4.23.0",
        "@suse-tmm/common": "workspace:^"
    }
